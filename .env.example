# =============================================================================
# Neuro ICU Scheduler - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Your existing backend)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000
VITE_REQUIRE_SUPABASE_AUTH=false

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
AI_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Error Tracking & Monitoring (Optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Notification Channels (Optional)
# -----------------------------------------------------------------------------
NOTIFY_WEBHOOK_URL=
NOTIFY_SLACK_WEBHOOK_URL=
NOTIFY_TEAMS_WEBHOOK_URL=
NOTIFY_EMAIL_WEBHOOK_URL=
NOTIFY_SMS_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Shared Memory Configuration
# -----------------------------------------------------------------------------
SHARED_MEMORY_PERSIST_INTERVAL=30000
SHARED_MEMORY_CLEANUP_INTERVAL=60000
SHARED_MEMORY_MAX_HISTORY=10000
SHARED_MEMORY_NAMESPACE=nicu-schedule

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=100
